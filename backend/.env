# Server Port
PORT=4000

# Database Configuration (XAMPP Default Settings)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=game_downloads

# Security / JWT Secrets (මේවා ඕනෙම අකුරු ගොඩක් වෙන්න පුළුවන්)
JWT_ACCESS_SECRET=super_secret_access_key_for_ankergames_123!@#
JWT_REFRESH_SECRET=super_secret_refresh_key_for_ankergames_456!@#

# Telegram Bot Token (මේක පස්සේ හදාගමු, දැනට නිකන් තියන්න)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
DOWNLOAD_SECRET=my_super_secure_download_secret_key_789!@#