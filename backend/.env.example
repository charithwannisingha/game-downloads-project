NODE_ENV=development
BACKEND_PORT=4000

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# JWT (access token)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=7d

# JWT (download token, short-lived, stateless)
DOWNLOAD_SECRET=change-me-download-secret
DOWNLOAD_EXPIRES_IN=10m

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=game_downloads

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF...

# Storage
UPLOADS_DIR=uploads

